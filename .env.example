# ======================================
# 종합사용툴 환경변수 설정 예시
# ======================================
# 이 파일을 복사해서 .env 로 만드세요
# 명령어: cp .env.example .env
# 그 다음 실제 API 키 값을 입력하세요
# ======================================

# YouTube Data API v3 키 (필수)
# 발급: https://console.cloud.google.com/
YOUTUBE_API_KEY=여기에_YOUTUBE_API_키_입력

# Gemini AI API 키 (선택 - AI 분석 기능용)
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_GEMINI_API_키_입력

# 서버 포트 (기본 3000)
PORT=3000

# 기본 국가 코드 (KR, JP, US 등)
DEFAULT_REGION=KR
