# =============================================
# 종합사용툴 v2.0 환경변수 예시
# 사용법: cp .env.example .env 후 실제 값 입력
# ⚠️ .env 파일은 절대 GitHub에 커밋하지 마세요.
# =============================================

# YouTube Data API v3 키 (필수) - Google Cloud Console에서 발급
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=여기에_YOUTUBE_API_키_입력

# 다중 키 로테이션 (선택) - 할당량이 부족할 때 자동 전환됨
# YOUTUBE_API_KEY_2=두_번째_키
# YOUTUBE_API_KEY_3=세_번째_키
# YOUTUBE_API_KEY_4=
# YOUTUBE_API_KEY_5=

# Google Gemini API 키 (선택) - AI 분석 기능용
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=여기에_GEMINI_API_키_입력

# 서버 포트 (기본 3000)
PORT=3000

# 기본 국가 (랭킹/트렌드 기본값)
DEFAULT_REGION=KR

# 일일 크롤 대상 국가 (쉼표 구분)
CRAWL_REGIONS=KR,US,JP
